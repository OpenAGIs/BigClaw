#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/../.." && pwd)
invocation_dir=$(pwd)
cd "$repo_root/bigclaw-go"
exec go run ./cmd/bigclawctl compat exec --repo-root "$repo_root" --invocation-dir "$invocation_dir" -- "$@"
