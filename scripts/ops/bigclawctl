#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/../.." && pwd)

cd "$repo_root/bigclaw-go"

needs_repo=true
for arg in "$@"; do
  case "$arg" in
    --repo|--repo=*)
      needs_repo=false
      ;;
  esac
done

if [ "$needs_repo" = true ]; then
  exec go run ./cmd/bigclawctl "$@" --repo "$repo_root"
fi

exec go run ./cmd/bigclawctl "$@"
