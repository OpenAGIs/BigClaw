#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/../.." && pwd)
invocation_dir=$(pwd)
go_root="$repo_root/bigclaw-go"
cache_root="${BIGCLAWCTL_BIN_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/bigclaw}"
bin_path="$cache_root/bigclawctl"

needs_build=0
if [[ ! -x "$bin_path" ]]; then
  needs_build=1
elif [[ "$go_root/go.mod" -nt "$bin_path" || "$go_root/go.sum" -nt "$bin_path" ]]; then
  needs_build=1
elif find "$go_root/cmd" "$go_root/internal" -type f -name '*.go' -newer "$bin_path" -print -quit | grep -q .; then
  needs_build=1
fi

if [[ "$needs_build" -eq 1 ]]; then
  mkdir -p "$cache_root"
  tmp_bin="$cache_root/.bigclawctl.$$"
  trap 'rm -f "$tmp_bin"' EXIT
  (
    cd "$go_root"
    GOWORK=off go build -o "$tmp_bin" ./cmd/bigclawctl
  )
  mv "$tmp_bin" "$bin_path"
  chmod +x "$bin_path"
  trap - EXIT
fi

needs_repo=true
out_args=()
consume_next_as_repo=0
for arg in "$@"; do
  if [ "$consume_next_as_repo" -eq 1 ]; then
    consume_next_as_repo=0
    if [[ "$arg" != /* && "$arg" != "~"* ]]; then
      if resolved_repo=$(cd "$invocation_dir" && cd "$arg" 2>/dev/null && pwd); then
        out_args+=("$resolved_repo")
      else
        out_args+=("$arg")
      fi
    else
      out_args+=("$arg")
    fi
    continue
  fi
  case "$arg" in
    --repo|--repo=*)
      needs_repo=false
      case "$arg" in
        --repo)
          out_args+=("$arg")
          consume_next_as_repo=1
          ;;
        --repo=*)
          repo_value="${arg#--repo=}"
          if [[ "$repo_value" != /* && "$repo_value" != "~"* ]]; then
            if resolved_repo=$(cd "$invocation_dir" && cd "$repo_value" 2>/dev/null && pwd); then
              out_args+=(--repo="$resolved_repo")
            else
              out_args+=("$arg")
            fi
          else
            out_args+=("$arg")
          fi
          ;;
      esac
      ;;
    *)
      out_args+=("$arg")
      ;;
  esac
done

if [ "$needs_repo" = true ]; then
  exec "$bin_path" "${out_args[@]}" --repo "$repo_root"
fi

exec "$bin_path" "${out_args[@]}"
