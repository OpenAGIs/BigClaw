#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/../.." && pwd)

translated=()
args=("$@")
i=0
while [ "$i" -lt "${#args[@]}" ]; do
  arg="${args[$i]}"
  case "$arg" in
    --report-file)
      i=$((i + 1))
      if [ "$i" -lt "${#args[@]}" ]; then
        translated+=(--report "${args[$i]}")
      fi
      ;;
    --report-file=*)
      translated+=(--report="${arg#--report-file=}")
      ;;
    --no-cleanup)
      translated+=(--cleanup=false)
      ;;
    --issues)
      i=$((i + 1))
      issues=()
      while [ "$i" -lt "${#args[@]}" ]; do
        next_arg="${args[$i]}"
        case "$next_arg" in
          -*)
            i=$((i - 1))
            break
            ;;
          *)
            issues+=("$next_arg")
            ;;
        esac
        i=$((i + 1))
      done
      if [ "${#issues[@]}" -gt 0 ]; then
        issue_csv=$(IFS=,; printf '%s' "${issues[*]}")
        translated+=(--issues "$issue_csv")
      else
        translated+=(--issues)
      fi
      ;;
    *)
      translated+=("$arg")
      ;;
  esac
  i=$((i + 1))
done

exec bash "$repo_root/scripts/ops/bigclawctl" workspace validate "${translated[@]}"
