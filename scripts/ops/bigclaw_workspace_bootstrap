#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/../.." && pwd)

has_repo_url=false
has_cache_key=false
out_args=()

for arg in "$@"; do
  case "$arg" in
    --repo-url|--repo-url=*)
      has_repo_url=true
      ;;
    --cache-key|--cache-key=*)
      has_cache_key=true
      ;;
  esac
  out_args+=("$arg")
done

if [ "$has_repo_url" = false ]; then
  out_args+=(--repo-url "${BIGCLAW_BOOTSTRAP_REPO_URL:-git@github.com:OpenAGIs/BigClaw.git}")
fi
if [ "$has_cache_key" = false ]; then
  out_args+=(--cache-key "${BIGCLAW_BOOTSTRAP_CACHE_KEY:-openagis-bigclaw}")
fi

exec bash "$repo_root/scripts/ops/bigclawctl" workspace "${out_args[@]}"
