#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

translated=()
while (($#)); do
  case "$1" in
    --report-file)
      if (($# < 2)); then
        echo "missing value for --report-file" >&2
        exit 2
      fi
      translated+=(--report "$2")
      shift 2
      ;;
    --report-file=*)
      translated+=(--report="${1#--report-file=}")
      shift
      ;;
    --no-cleanup)
      translated+=(--cleanup=false)
      shift
      ;;
    --issues)
      shift
      issues=()
      while (($#)) && [[ "$1" != -* ]]; do
        issues+=("$1")
        shift
      done
      translated+=(--issues "$(IFS=,; printf '%s' "${issues[*]}")")
      ;;
    *)
      translated+=("$1")
      shift
      ;;
  esac
done

exec bash "$script_dir/bigclawctl" workspace validate "${translated[@]}"
