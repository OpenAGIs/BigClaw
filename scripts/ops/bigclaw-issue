#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/../.." && pwd)
workflow="$repo_root/workflow.md"

if [ "$#" -gt 0 ]; then
  case "$1" in
    list|create|state|comment)
      exec bash "$repo_root/scripts/ops/bigclawctl" local-issues "$@"
      ;;
  esac
fi

if [ -x "$repo_root/../elixir/bin/symphony" ]; then
  exec "$repo_root/../elixir/bin/symphony" issue --workflow "$workflow" "$@"
fi

if command -v symphony >/dev/null 2>&1; then
  exec symphony issue --workflow "$workflow" "$@"
fi

echo "symphony CLI not found. Install Symphony or run from a checkout that contains ../elixir/bin/symphony." >&2
exit 1
