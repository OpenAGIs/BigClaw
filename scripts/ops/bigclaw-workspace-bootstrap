#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

has_flag() {
  local flag="$1"
  shift
  local prefix="${flag}="
  for arg in "$@"; do
    if [[ "$arg" == "$flag" || "$arg" == "$prefix"* ]]; then
      return 0
    fi
  done
  return 1
}

args=("$@")
if ! has_flag --repo-url "${args[@]}"; then
  args+=(--repo-url "${BIGCLAW_BOOTSTRAP_REPO_URL:-git@github.com:OpenAGIs/BigClaw.git}")
fi
if ! has_flag --cache-key "${args[@]}"; then
  args+=(--cache-key "${BIGCLAW_BOOTSTRAP_CACHE_KEY:-openagis-bigclaw}")
fi

exec bash "$script_dir/bigclawctl" workspace bootstrap "${args[@]}"
