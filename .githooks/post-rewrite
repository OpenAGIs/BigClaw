#!/usr/bin/env bash
set -u

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$repo_root" || exit 0

if [ "${BIGCLAW_SKIP_AUTO_SYNC:-0}" = "1" ]; then
  exit 0
fi

export PYTHONDONTWRITEBYTECODE=1

if [ ! -f "scripts/ops/bigclaw_github_sync.py" ]; then
  exit 0
fi

python3 scripts/ops/bigclaw_github_sync.py sync --json || {
  echo "[bigclaw-sync] post-rewrite auto-sync failed; inspect branch sync state." >&2
  exit 0
}
