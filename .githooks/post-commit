#!/usr/bin/env bash
set -u

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$repo_root" || exit 0

if [ "${BIGCLAW_SKIP_AUTO_SYNC:-0}" = "1" ]; then
  exit 0
fi

export PYTHONDONTWRITEBYTECODE=1

if [ ! -f "scripts/ops/bigclawctl" ]; then
  exit 0
fi

bash scripts/ops/bigclawctl github-sync sync --json --allow-dirty || {
  echo "[bigclaw-sync] post-commit auto-sync failed; inspect branch sync state." >&2
  exit 0
}
