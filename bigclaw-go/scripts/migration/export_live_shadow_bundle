#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

needs_go_root=1
for arg in "$@"; do
  case "$arg" in
    --go-root|--go-root=*)
      needs_go_root=0
      ;;
  esac
done

if [[ "$needs_go_root" -eq 1 ]]; then
  exec go run "$ROOT/cmd/bigclawctl" automation migration export-live-shadow-bundle --go-root "$ROOT" "$@"
fi

exec go run "$ROOT/cmd/bigclawctl" automation migration export-live-shadow-bundle "$@"
