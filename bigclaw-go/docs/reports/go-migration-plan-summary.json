  "major_risks": [
    {
      "risk": "Python scripts keep generating canonical reports while Go only emits parallel outputs.",
      "mitigation": "Prioritize migration/*.py, export_validation_bundle.py, and run_all.sh into bigclawctl."
    },
    {
      "risk": "Frozen Python modules remain operator or documentation entrypoints during cutover.",
      "mitigation": "Unify CLI entrypoints and legacy shims before deleting Python paths."
    },
    {
      "risk": "Schema drift appears while Python and Go both define task or report contracts.",
      "mitigation": "Treat contract assets as P0 and make Go the single schema authority."
    },
    {
      "risk": "P2 product surfaces create oversized PRs and slow the cutover.",
      "mitigation": "Preserve payload parity first, then decide whether to port internal implementations fully."
    },
    {
      "risk": "Shell wrappers survive after Go command parity, leaving local workflows inconsistent.",
      "mitigation": "Collapse every wrapper into bigclawctl subcommands."
    }
  ]
